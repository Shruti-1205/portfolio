---
import { education } from '../data/education';
---
<section id="education" class="max-w-page mx-auto px-6 py-20 border-t border-line">
  <h2 class="font-serif text-3xl md:text-4xl mb-10 tracking-tightish">Education</h2>
  <div class="space-y-10">
    {education.map((e) => (
      <div class="grid md:grid-cols-[200px_1fr] gap-4 md:gap-8">
        <p class="text-sm text-muted font-mono pt-1">{e.dates}</p>
        <div>
          <h3 class="font-medium text-lg leading-snug">{e.degree}</h3>
          <p class="text-muted mt-1">{e.school}, {e.location}</p>
          <p class="text-sm font-mono text-accent mt-2">GPA {e.gpa}</p>
        </div>
      </div>
    ))}
  </div>
</section>
