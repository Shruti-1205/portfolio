---
const links = [
  { href: '#about', label: 'About' },
  { href: '#experience', label: 'Experience' },
  { href: '#projects', label: 'Projects' },
  { href: '#publications', label: 'Publications' },
  { href: '#skills', label: 'Skills' },
  { href: '#contact', label: 'Contact' },
];
---
<nav class="sticky top-0 z-40 bg-bg/80 backdrop-blur-md border-b border-line">
  <div class="max-w-page mx-auto px-6 py-4 flex items-center justify-between">
    <a href="#top" class="font-serif text-xl tracking-tightish hover:text-accent transition">
      Shruti <span class="italic">Devlekar</span>
    </a>
    <ul class="hidden md:flex items-center gap-7 text-sm text-muted">
      {links.map((l) => (
        <li>
          <a href={l.href} class="hover:text-ink transition">{l.label}</a>
        </li>
      ))}
    </ul>
  </div>
</nav>
