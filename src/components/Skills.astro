---
import { skills } from '../data/skills';
---
<section id="skills" class="max-w-page mx-auto px-6 py-20 border-t border-line">
  <h2 class="font-serif text-3xl md:text-4xl mb-10 tracking-tightish">Skills</h2>
  <div class="grid md:grid-cols-2 gap-10">
    {Object.entries(skills).map(([group, items]) => (
      <div>
        <h3 class="text-xs font-mono uppercase tracking-[0.15em] text-accent mb-4">{group}</h3>
        <div class="flex flex-wrap gap-2">
          {items.map((s) => (
            <span class="text-sm px-3 py-1 border border-line rounded-full text-ink/85 hover:border-ink transition">
              {s}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
